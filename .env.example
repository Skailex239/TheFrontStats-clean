# ── OpenRuns — Configuration ──────────────────────────
# Copier ce fichier en .env et remplir les valeurs

# Clé d'exemption API OpenFront (auto-sync / server.js)
# Obtenir la clé : contacter les devs OpenFront sur Discord
OPENFRONT_SKAILEX_ACCESS=

# Port du serveur
PORT=3000

# Nombre max de fenêtres historique par exécution de sync (défaut: 500 avec exemption, 40 sans)
SYNC_HISTORY_WINDOWS=

# Firebase — clés déjà côté client (pas besoin ici, mais utile pour scripts serveur futurs)
# FIREBASE_API_KEY=
# FIREBASE_PROJECT_ID=openfront-speedrun
